---
import config from 'virtual:config'

import { Icon } from 'astro-pure/user'
---

<header-component
  class='group sticky top-4 z-50 max-md:z-30 mb-12 flex items-center justify-between rounded-xl border border-transparent max-sm:py-1 sm:rounded-2xl'
>
  <a
    class='z-30 text-xl font-medium group-[.not-top]:ms-2 sm:group-[.not-top]:ms-3'
    style='transition:margin-inline 0.3s'
    href='/'
    aria-label='Brand'>{config.title}</a
  >

  <div class='flex items-center gap-x-2'>
    {/* Menu links */}
    <div
      id='headerExpandContent'
      class='end-0 start-0 top-12 grid border border-transparent group-[.not-top]:rounded-xl group-[.expanded]:opacity-100 dark:group-[.expanded.not-top]:bg-muted max-sm:absolute max-sm:opacity-0 max-sm:group-[.not-top]:border-border max-sm:group-[.expanded.not-top]:bg-background max-sm:group-[.not-top]:px-4 max-sm:group-[.not-top]:py-2 sm:grid-rows-1'
    >
      <div class='flex flex-col items-center justify-center overflow-hidden sm:flex-row'>
        {
          config.header.menu.map((item) => (
            <a
              href={item.link}
              class='w-full flex-none grow py-2 text-right font-medium transition-none hover:text-primary sm:w-fit sm:px-3'
              aria-label='Nav menu item'
              data-astro-prefetch
            >
              {item.title}
            </a>
          ))
        }
        <div class='flex w-full grow flex-row justify-end gap-x-3 sm:w-fit sm:gap-x-5'>
          <a class='px-1 py-2 transition-none sm:px-2' href='/search' title='Search'>
            <span class='sr-only'>Search</span>
            <Icon name='search' class='size-5' />
          </a>
        </div>
      </div>
    </div>

    {/* buttons */}
    <div class='z-30 flex gap-x-4 group-[.not-top]:gap-x-2' style='transition:gap 0.3s'>
      <button
        id='toggleDarkMode'
        class='group/dark box-content size-5 rounded-md border p-1.5 transition-colors hover:bg-border sm:group-[.not-top]:rounded-xl'
      >
        <span class='sr-only'>Dark Theme</span>
        <Icon class='light hidden size-5 group-hover/dark:text-primary' name='sun' />
        <Icon class='dark hidden size-5 group-hover/dark:text-primary' name='moon' />
      </button>
      <button
        id='toggleMenu'
        class='rounded-md border p-1.5 transition-colors hover:bg-border sm:hidden sm:group-[.not-top]:rounded-xl'
      >
        <span class='sr-only'>Menu</span>
        <Icon class='size-5' name='menu' />
      </button>
    </div>
  </div>
</header-component>

{/* Use inline to load icon quicker firstly */}
<script is:inline>
  const toggleDarkModeElement = document.getElementById('toggleDarkMode')
  if (toggleDarkModeElement) {
    toggleDarkModeElement.dataset.theme = document.documentElement.classList.contains('dark')
      ? 'dark'
      : 'light'
  }

  window.__liquidHeaderCleanup?.()
  const liquidHeaderElement = document.querySelector('header-component')
  if (liquidHeaderElement) {
    let previousScrollY =
      window.scrollY || document.documentElement.scrollTop || document.body.scrollTop || 0
    let ticking = false
    const updateLiquidHeader = () => {
      ticking = false
      const currentScrollY =
        window.scrollY || document.documentElement.scrollTop || document.body.scrollTop || 0
      liquidHeaderElement.classList.toggle('not-top', currentScrollY > 20)
      liquidHeaderElement.dataset.show = (
        currentScrollY < 400 || currentScrollY < previousScrollY
      ).toString()
      previousScrollY = currentScrollY
    }
    const requestLiquidHeaderUpdate = () => {
      if (ticking) return
      ticking = true
      requestAnimationFrame(updateLiquidHeader)
    }

    updateLiquidHeader()
    window.addEventListener('scroll', requestLiquidHeaderUpdate, { passive: true })
    document.addEventListener('astro:page-load', updateLiquidHeader)
    window.__liquidHeaderCleanup = () => {
      window.removeEventListener('scroll', requestLiquidHeaderUpdate)
      document.removeEventListener('astro:page-load', updateLiquidHeader)
    }
  }
</script>
<script>
  class HeaderComponent extends HTMLElement {
    connectedCallback() {
      // Header
      let preScrollY = window.scrollY
      let ticking = false
      const updateHeader = () => {
        ticking = false
        const currentScrollY =
          window.scrollY || document.documentElement.scrollTop || document.body.scrollTop || 0
        this.classList.toggle('not-top', currentScrollY > 20)
        this.dataset.show = (currentScrollY < 400 || currentScrollY < preScrollY).toString()
        preScrollY = currentScrollY
      }
      const requestHeaderUpdate = () => {
        if (ticking) return
        ticking = true
        requestAnimationFrame(updateHeader)
      }
      updateHeader()
      window.addEventListener('scroll', requestHeaderUpdate, { passive: true })

      // Dark Mode
      const darkModeBtn = this.querySelector('#toggleDarkMode') as HTMLElement
      darkModeBtn.addEventListener('click', (event) => {
        event.stopPropagation()
        const isDark = document.documentElement.classList.contains('dark')
        const newTheme = isDark ? 'light' : 'dark'

        localStorage.setItem('theme', newTheme)
        document.documentElement.classList.toggle('dark', newTheme === 'dark')
        document
          .querySelector('meta[name="theme-color"]')
          ?.setAttribute('content', newTheme === 'dark' ? '#0B0B10' : '#FCFCFD')
        darkModeBtn.dataset.theme = newTheme
        document.dispatchEvent(
          new CustomEvent('toast', { detail: { message: `Set theme to ${newTheme}` } })
        )
      })

      // Menu
      this.querySelector('#toggleMenu')?.addEventListener('click', (event) => {
        event.stopPropagation()
        this.classList.toggle('expanded')
      })
    }
  }

  if (!customElements.get('header-component')) {
    customElements.define('header-component', HeaderComponent)
  }
</script>

<style>
  header-component {
    position: sticky;
    isolation: isolate;
    transform-origin: top center;
    transition:
      padding 0.3s,
      transform 0.3s,
      margin-inline 0.3s,
      border 0.15s,
      background-color 0.15s,
      box-shadow 0.2s;
    will-change: transform;

    & > * {
      position: relative;
      z-index: 1;
    }

    &::before {
      content: '';
      position: absolute;
      inset: 0;
      z-index: 0;
      pointer-events: none;
      border-radius: inherit;
      opacity: 0;
      transition:
        opacity 0.2s,
        box-shadow 0.2s,
        background 0.2s;
    }

    &::after {
      content: '';
      position: absolute;
      inset: 1px;
      z-index: 0;
      pointer-events: none;
      border-radius: inherit;
      opacity: 0;
      transition: opacity 0.2s;
      background:
        radial-gradient(circle at 18% 0%, rgba(255, 255, 255, 0.65), transparent 24%),
        linear-gradient(115deg, rgba(255, 255, 255, 0.22), transparent 36% 64%, rgba(255, 255, 255, 0.12));
      mix-blend-mode: screen;
    }

    &.not-top {
      --un-border-opacity: 1;
      border-color: rgba(255, 255, 255, 0.38);
      --un-bg-opacity: 1;
      background-color: rgba(255, 255, 255, 0.48);
      padding-left: 0.375rem;
      padding-right: 0.375rem;
      margin-inline: clamp(1rem, 10vw, 7rem);
      transform: scaleX(0.96);
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.78),
        inset 0 -1px 0 rgba(255, 255, 255, 0.18),
        0 0 0 1px rgba(255, 255, 255, 0.2),
        0 18px 42px rgba(15, 23, 42, 0.12),
        0 6px 16px rgba(15, 23, 42, 0.08);

      &::before {
        opacity: 1;
        background:
          linear-gradient(135deg, rgba(255, 255, 255, 0.72), rgba(255, 255, 255, 0.2) 38%, rgba(255, 255, 255, 0.36)),
          color-mix(in srgb, hsl(var(--background)) 74%, transparent);
        box-shadow:
          inset 0 0 18px rgba(255, 255, 255, 0.26),
          inset 12px 0 28px rgba(255, 255, 255, 0.16),
          inset -12px 0 28px rgba(255, 255, 255, 0.1);
      }

      &::after {
        opacity: 0.7;
      }
    }
    &[data-show='false']:not(.expanded) {
      transform: translateY(-5rem) scaleX(0.96);
    }
  }
  :global(.dark) header-component.not-top {
    border-color: rgba(255, 255, 255, 0.14);
    background-color: rgba(24, 24, 27, 0.5);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.18),
      inset 0 -1px 0 rgba(255, 255, 255, 0.05),
      0 0 0 1px rgba(255, 255, 255, 0.08),
      0 18px 42px rgba(0, 0, 0, 0.28),
      0 6px 16px rgba(0, 0, 0, 0.18);

    &::before {
      background:
        linear-gradient(135deg, rgba(255, 255, 255, 0.15), rgba(255, 255, 255, 0.04) 42%, rgba(255, 255, 255, 0.1)),
        color-mix(in srgb, hsl(var(--muted)) 62%, transparent);
      box-shadow:
        inset 0 0 18px rgba(255, 255, 255, 0.08),
        inset 12px 0 28px rgba(255, 255, 255, 0.06),
        inset -12px 0 28px rgba(255, 255, 255, 0.04);
    }

    &::after {
      opacity: 0.32;
    }
  }
  @media (min-width: 641px) {
    header-component.not-top,
    header-component.expanded.not-top #headerExpandContent {
      backdrop-filter: blur(22px) saturate(180%);
      -webkit-backdrop-filter: blur(22px) saturate(180%);
    }
  }

  @media (max-width: 640px) {
    header-component {
      transition:
        padding 0.3s,
        transform 0.3s,
        border 0.15s,
        background-color 0.15s,
        box-shadow 0.2s;
    }

    header-component.not-top {
      margin-inline: 0;
    }

    header-component[data-show='false']:not(.expanded) {
      transform: translateY(-5rem);
    }

    #headerExpandContent {
      grid-template-rows: 0fr;
      transition:
        opacity 0.3s,
        padding 0.3s,
        border-color 0.15s,
        grid-template-rows 0.3s;
    }
    .expanded #headerExpandContent {
      grid-template-rows: 1fr;
    }
    .expanded.not-top #headerExpandContent {
      background-color: rgba(255, 255, 255, 0.52);
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.64),
        0 18px 42px rgba(15, 23, 42, 0.12),
        0 6px 16px rgba(15, 23, 42, 0.08);
    }
    :global(.dark) .expanded.not-top #headerExpandContent {
      background-color: rgba(24, 24, 27, 0.58);
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.14),
        0 18px 42px rgba(0, 0, 0, 0.28),
        0 6px 16px rgba(0, 0, 0, 0.18);
    }

    /* header component after */
    header-component #headerExpandContent::after {
      box-sizing: content-box;
      content: '';
      position: absolute;
      inset-inline: calc(-1rem - 1px);
      bottom: 0;
      top: -5rem;
      z-index: -1;
      transition: 0.3s;
      visibility: hidden;
      opacity: 0;
      border-bottom: 1px solid transparent;
    }
    header-component:not(.not-top) #headerExpandContent::after {
      visibility: visible;
      bottom: -1rem;
      opacity: 1;
      background-color: hsl(var(--muted) / var(--un-bg-opacity, 1));
      border-bottom-color: hsl(var(--border) / var(--un-border-opacity, 1));
    }
  }

  header-component > * {
    position: relative;
    z-index: 1;
  }
  header-component::before,
  header-component::after {
    content: '';
    position: absolute;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.2s;
  }
  header-component::before {
    inset: 0;
    z-index: 0;
    border-radius: inherit;
    transition:
      opacity 0.2s,
      box-shadow 0.2s,
      background 0.2s;
  }
  header-component::after {
    inset: 1px;
    z-index: 0;
    border-radius: inherit;
    background:
      radial-gradient(circle at 18% 0%, rgba(255, 255, 255, 0.36), transparent 24%),
      linear-gradient(
        115deg,
        rgba(255, 255, 255, 0.1),
        transparent 36% 64%,
        rgba(255, 255, 255, 0.05)
      );
    mix-blend-mode: screen;
  }
  header-component.not-top {
    border-color: rgba(255, 255, 255, 0.2);
    background-color: rgba(255, 255, 255, 0.2);
    margin-inline: clamp(1rem, 10vw, 7rem);
    padding-left: 0.375rem;
    padding-right: 0.375rem;
    transform: scaleX(0.96);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.42),
      inset 0 -1px 0 rgba(255, 255, 255, 0.07),
      0 0 0 1px rgba(255, 255, 255, 0.08),
      0 18px 42px rgba(15, 23, 42, 0.1),
      0 6px 16px rgba(15, 23, 42, 0.06);
  }
  header-component.not-top::before {
    opacity: 1;
    background:
      linear-gradient(
        135deg,
        rgba(255, 255, 255, 0.28),
        rgba(255, 255, 255, 0.07) 38%,
        rgba(255, 255, 255, 0.12)
      ),
      color-mix(in srgb, hsl(var(--background)) 32%, transparent);
    box-shadow:
      inset 0 0 18px rgba(255, 255, 255, 0.1),
      inset 12px 0 28px rgba(255, 255, 255, 0.05),
      inset -12px 0 28px rgba(255, 255, 255, 0.03);
  }
  header-component.not-top::after {
    opacity: 0.36;
  }
  header-component[data-show='false']:not(.expanded) {
    transform: translateY(-5rem) scaleX(0.96);
  }
  :global(.dark) header-component.not-top {
    border-color: rgba(255, 255, 255, 0.05);
    background-color: rgba(10, 10, 14, 0.34);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.05),
      inset 0 -1px 0 rgba(255, 255, 255, 0.02),
      0 0 0 1px rgba(255, 255, 255, 0.025),
      0 18px 42px rgba(0, 0, 0, 0.3),
      0 6px 16px rgba(0, 0, 0, 0.18);
  }
  :global(.dark) header-component.not-top::before {
    background:
      linear-gradient(
        135deg,
        rgba(255, 255, 255, 0.035),
        rgba(255, 255, 255, 0.01) 42%,
        rgba(255, 255, 255, 0.02)
      ),
      color-mix(in srgb, hsl(var(--background)) 26%, rgba(0, 0, 0, 0.42));
    box-shadow:
      inset 0 0 20px rgba(0, 0, 0, 0.14),
      inset 14px 0 28px rgba(255, 255, 255, 0.015),
      inset -14px 0 28px rgba(255, 255, 255, 0.01);
  }
  :global(.dark) header-component.not-top::after {
    opacity: 0.1;
  }

  /* dark light mode toggle */
  #toggleDarkMode {
    &[data-theme='dark'] {
      & .dark {
        display: block;
      }
    }
    &[data-theme='light'] {
      .light {
        display: block;
      }
    }
  }
</style>
